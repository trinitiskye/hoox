# ------ REQUIRED: Get from Supabase Dashboard ------
# Go to: https://supabase.com/dashboard/project/iefjracmxpkpwndrksps/settings/api

# Your Supabase project URL (always this format)
NEXT_PUBLIC_SUPABASE_URL=https://iefjracmxpkpwndrksps.supabase.co

# Anon/public key - safe to expose in browser (RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key - NEVER expose publicly, only for server-side use
# (Not needed for current app - keep for future API routes)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ------ OPTIONAL: App Config ------
NEXT_PUBLIC_APP_NAME=FishTournament Pro
NEXT_PUBLIC_APP_FEE=6.50
NEXT_PUBLIC_ADMIN_EMAIL=admin@fishtournament.com
